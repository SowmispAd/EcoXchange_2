generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

enum Role {
  ADMIN
  MEMBER
  SUPERVISOR
  AGENT
  RECYCLER
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email      String   @unique
  password   String
  role       Role     @default(MEMBER)

  ecoPoints  Int      @default(0)

  createdAt  DateTime @default(now())
}